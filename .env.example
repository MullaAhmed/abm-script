# =============================================================================
# ABM Script Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- AI Provider (required) ---
ANTHROPIC_API_KEY=sk-ant-...
ABM_AI_MODEL=claude-sonnet-4-6

# --- Identity Provider ---
# Options: rb2b | clearbit-reveal
IDENTITY_PROVIDER=rb2b
RB2B_API_KEY=your_rb2b_api_key
# CLEARBIT_API_KEY=your_clearbit_api_key

# --- Storage / Cache ---
# Options: memory | file
STORAGE_TYPE=memory
CACHE_TTL=3600
# Directory for file-based cache (only used when STORAGE_TYPE=file)
CACHE_DIR=.abm-cache

# --- Server ---
HOST=0.0.0.0
PORT=8001
# Comma-separated allowed origins, or * for all
CORS_ORIGINS=*
DEBUG=false
