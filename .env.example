# =============================================================================
# ABM Script Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- AI Provider (required) ---
OPENAI_API_KEY=sk-...
ABM_AI_MODEL=gpt-4.1-nano

# --- Identity (Tomba + Apify company enricher) ---
TOMBA_API_KEY=ta_...
TOMBA_API_SECRET=ts_...
APIFY_TOKEN=apify_api_...

# --- Storage / Cache ---
# Options: memory | file
STORAGE_TYPE=memory
CACHE_TTL=3600
# Directory for file-based cache (only used when STORAGE_TYPE=file)
CACHE_DIR=.abm-cache

# --- Server ---
HOST=0.0.0.0
PORT=8001
# Comma-separated allowed origins, or * for all
CORS_ORIGINS=*
DEBUG=false
