# =============================================================================
# ABM Script Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- AI Provider (required) ---
OPENAI_API_KEY=sk-...
ABM_AI_MODEL=openai/gpt-5-nano

# --- Identity Provider ---
# Options: pdl | rb2b | clearbit-reveal | ip-api
# ip-api is free (no API key needed) — good for demos
IDENTITY_PROVIDER=pdl
PDL_API_KEY=your_pdl_api_key
# RB2B_API_KEY=your_rb2b_api_key
# CLEARBIT_API_KEY=your_clearbit_api_key

# --- Storage / Cache ---
# Options: memory | file
STORAGE_TYPE=memory
CACHE_TTL=3600
# Directory for file-based cache (only used when STORAGE_TYPE=file)
CACHE_DIR=.abm-cache

# --- Server ---
HOST=0.0.0.0
PORT=8001
# Comma-separated allowed origins, or * for all
CORS_ORIGINS=*
DEBUG=false
